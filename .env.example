# ----------------------------------------------------------------------------
# CivicOS environment — copy to `.env` and adjust for your city/country.
# Everything has a sensible development default, so `docker compose up` works
# with no changes at all.
# ----------------------------------------------------------------------------

# Database (postgres:15-alpine — aligned with the rest of the workspace).
# By default Postgres/Redis are NOT published to the host (the backend reaches
# them over the internal Docker network), so these ports only matter if you
# uncomment the `ports:` blocks in docker-compose.yml to inspect them.
POSTGRES_USER=civicos
POSTGRES_PASSWORD=civicos
POSTGRES_DB=civicos
POSTGRES_PORT=5433               # free host port if you choose to expose it

# Redis
REDIS_PORT=6380                  # free host port if you choose to expose it

# Backend — 8100 because 8000/8001-8012/8080 are used by other projects.
BACKEND_PORT=8100
ENVIRONMENT=development          # development | production
JWT_SECRET=dev-secret-change-me  # CHANGE THIS in production (long random string)
OTP_DEBUG_RETURN=true            # return OTP in API response (dev only!)
CORS_ORIGINS=*                   # comma-separated origins, or * for any

# Frontend — 3100 because 3000/3001 are used by other projects.
FRONTEND_PORT=3100
VITE_API_URL=http://localhost:8100

# Optional single-origin reverse proxy (docker compose --profile proxy up)
PROXY_PORT=8090

# Notifications — leave blank to use console.log (dev). Fill to enable real SMS.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
